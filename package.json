{
  "name": "paddock",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "backfill:races": "node --env-file=.env.local --import tsx scripts/backfill-races.mts",
    "backfill:pets": "node --env-file=.env.local --import tsx scripts/backfill-pets.mts",
    "verify:phase1": "node --env-file=.env.local --import tsx scripts/verify-phase1.mts",
    "typecheck": "tsc --noEmit",
    "materialize": "node --env-file=.env.local --import tsx scripts/materialize-scores.mts",
    "verify:phase2": "node --env-file=.env.local --import tsx scripts/verify-phase2.mts",
    "backfill:market": "node --env-file=.env.local --import tsx scripts/backfill-market.mts",
    "test:e2e": "playwright test",
    "screenshots": "playwright test --project=mobile-380",
    "backtest:odds": "node --env-file=.env.local scripts/backtest-odds.mjs",
    "validate:shark": "node --env-file=.env.local scripts/validate-shark.mjs",
    "test:signer": "node --import tsx scripts/signer-rejection-test.mts",
    "catchup:races": "node --env-file=.env.local --import tsx scripts/catchup-races.mts",
    "ingest:all": "node --env-file=.env.local --import tsx scripts/ingest-all.mts"
  },
  "dependencies": {
    "@abstract-foundation/agw-client": "^1.12.3",
    "@abstract-foundation/agw-react": "^1.13.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.52.2",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
