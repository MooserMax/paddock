{
  "name": "paddock",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "backfill:races": "node --env-file=.env.local --import tsx scripts/backfill-races.mts",
    "backfill:pets": "node --env-file=.env.local --import tsx scripts/backfill-pets.mts",
    "verify:phase1": "node --env-file=.env.local --import tsx scripts/verify-phase1.mts",
    "typecheck": "tsc --noEmit",
    "materialize": "node --env-file=.env.local --import tsx scripts/materialize-scores.mts",
    "verify:phase2": "node --env-file=.env.local --import tsx scripts/verify-phase2.mts",
    "backfill:market": "node --env-file=.env.local --import tsx scripts/backfill-market.mts",
    "test:e2e": "playwright test",
    "screenshots": "playwright test --project=mobile-380",
    "backtest:odds": "node --env-file=.env.local scripts/backtest-odds.mjs",
    "validate:shark": "node --env-file=.env.local scripts/validate-shark.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
