# Paddock environment. Copy to .env.local and fill in.
# This project uses its OWN dedicated Supabase project. No values are shared
# with any other project.

# Supabase (Project Settings -> API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for cron endpoints. Vercel sends it automatically as
# "Authorization: Bearer ..." when this env var is set on the project.
# Generate one with: openssl rand -hex 32
CRON_SECRET=

# OpenSea API key (https://docs.opensea.io) for the sales cron.
OPENSEA_API_KEY=

# Abstract chain RPC. The public endpoint works; override if you have a
# dedicated one.
RPC_URL=https://api.mainnet.abs.xyz

# -----------------------------------------------------------------------------
# Security forensics harness (scripts/contract-forensics.mjs, approval-forensics.mjs).
# All OPTIONAL: both scripts are read-only, keyless, and run with zero config
# against the public RPC. Set these only to point at your own key/RPC.
# -----------------------------------------------------------------------------
# Abstract RPC for the forensics scripts (falls back to RPC_URL, then public RPC).
ABSTRACT_RPC_URL=https://api.mainnet.abs.xyz
# Etherscan V2 API key (chainid 2741) to fetch verified source via API instead of
# the keyless public explorer page. Never commit a real key.
ABSCAN_API_KEY=
# Wallet to audit in approval-forensics.mjs (or pass as the first CLI arg).
FORENSICS_WALLET=
# First block to scan for approval history (default 67000000).
APPROVAL_START_BLOCK=
