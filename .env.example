# Paddock environment. Copy to .env.local and fill in.
# This project uses its OWN dedicated Supabase project. No values are shared
# with any other project.

# Supabase (Project Settings -> API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for cron endpoints. Vercel sends it automatically as
# "Authorization: Bearer ..." when this env var is set on the project.
# Generate one with: openssl rand -hex 32
CRON_SECRET=

# OpenSea API key (https://docs.opensea.io) for the sales cron.
OPENSEA_API_KEY=

# Abstract chain RPC. The public endpoint works; override if you have a
# dedicated one.
RPC_URL=https://api.mainnet.abs.xyz
